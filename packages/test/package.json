{
    "name": "test-package",
    "version": "0.0.1",
    "devDependencies": {
        "chai": "6.2.2",
        "enzyme": "3.11.0",
        "expect": "30.2.0",
        "jest": "30.2.0",
        "mocha": "11.7.5",
        "react-test-renderer": "19.2.4",
        "sinon": "21.0.2",
        "sinon-chai": "4.0.1"
    },
    "scripts": {
        "test": "cd ../../ && cross-env NODE_ENV=development ./node_modules/.bin/mocha --require @babel/register \"./src/**/*.spec.js\" && cd -",
        "jest-test": "cd ../../ && jest",
        "coverage": "cd ../../ && jest --coverage --no-cache --ci --runInBand"
    }
}
