{
    "name": "test-package",
    "version": "0.0.1",
    "devDependencies": {
        "chai": "6.2.2",
        "enzyme": "3.11.0",
        "enzyme-adapter-react-16": "1.15.8",
        "enzyme-to-json": "3.6.2",
        "expect": "30.2.0",
        "istanbul": "0.4.5",
        "jest": "30.2.0",
        "jest-emotion-react": "0.0.2",
        "jest-glamor-react": "4.3.1",
        "mocha": "11.7.5",
        "react-test-renderer": "19.2.4",
        "redux-mock-store": "1.5.5",
        "sinon": "21.0.2",
        "sinon-chai": "4.0.1"
    },
    "scripts": {
        "test": "cd ../../ && cross-env NODE_ENV=development ./node_modules/.bin/mocha --require @babel/register \"./src/**/*.spec.js\" && cd -",
        "jest-test": "jest",
        "coverage": "jest --coverage --no-cache --ci --runInBand",
        "cover": "cd ../../ && ./node_modules/.bin/istanbul cover ./node_modules/.bin/_mocha -- --require @babel/register \"./src/frontend/js/**/*.spec.js\" && cd -"
    }
}
