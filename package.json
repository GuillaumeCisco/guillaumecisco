{
    "private": true,
    "name": "guillaumecisco",
    "packageManager": "yarn@4.13.0",
    "productName": "Guillaume Cisco Website",
    "author": "Guillaume Cisco <guillaumecisco@gmail.com>",
    "version": "0.0.1",
    "license": "MIT",
    "description": "Guillaume Cisco's website",
    "repository": {
        "type": "git",
        "url": "https://github.com/GuillaumeCisco/guillaumecisco"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "cd packages/ssr && yarn build:dev && cd ../.. && nodemon src/server/main.js",
        "build": "rm -Rf ./public && NODE_ENV=production yarn build:webpack && yarn build:lib",
        "build:dev": "rm -Rf ./public && NODE_ENV=development yarn build:webpack",
        "build:webpack": "cd packages/ssr && npm run build:webpack",
        "build:lib": "cd packages/ssr && npm run build:lib",
        "start": "NODE_ENV=production node lib/server/main.js",
        "clean": "rimraf lib && rimraf public",
        "test": "cd packages/test && npm run test",
        "cover": "cd packages/test && npm run cover",
        "eslint": "cd packages/eslint && npm run eslint",
        "deploy": "tools/deploy.js",
        "precommit-msg": "echo 'Pre-commit checks...' && exit 0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "pre-commit": [
        "precommit-msg",
        "test",
        "eslint"
    ],
    "devDependencies": {
        "nodemon": "^3.1.14"
    }
}
